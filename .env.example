# ==============================================================================
# VIEMS Next.js Environment Variables Template
# ==============================================================================

# Backend Server URL (used by Next.js rewrites in next.config.ts)
# Local Default: http://localhost:8081
# Vercel Production Example: https://api.viems.com
BACKEND_URL=http://localhost:8081

# Public Client-side Backend URL (optional override)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8081
